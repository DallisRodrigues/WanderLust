<% layout ("/layouts/boilerplate") -%>
    <style>
        #filters {
            display: flex;
            align-items: center;
            overflow-x: auto; /* Makes it scrollable on small screens */
            gap: 2rem; /* Replaces margin-right for cleaner spacing */
            margin-top: 1rem;
            padding-bottom: 1rem;
        }

        /* Hides the ugly scrollbar while keeping the scroll functionality */
        #filters::-webkit-scrollbar {
            display: none;
        }

        /* Changed from div to anchor tags, so we must remove text decoration */
        .filter {
            text-align: center;
            opacity: 0.7;
            text-decoration: none; 
            color: inherit;
            flex-shrink: 0; /* Prevents icons from squishing on mobile */
            transition: opacity 0.2s ease;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter p {
            font-size: 0.8rem;
            margin-bottom: 0;
            margin-top: 0.5rem;
        }

        .tax-info {
            display: none;
        }
        
        .tax-toggle {
            border: 1px solid rgba(0, 0, 0, 0.2); /* Fixed border syntax */
            border-radius: 1rem;
            height: 3.25rem;
            padding: 1rem;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        .active-filter {
            opacity: 1 !important;
            border-bottom: 3px solid #fe424d; 
            padding-bottom: 0.2rem;
        }
    </style>

    <div id="filters">
        <a href="/listings?category=Trending" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Trending' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </a>
        <a href="/listings?category=Rooms" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Rooms' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </a>
        <a href="/listings?category=Iconic Cities" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Iconic Cities' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </a>
        <a href="/listings?category=Mountains" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Mountains' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </a>
        <a href="/listings?category=Castles" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Castles' ? 'active-filter' : '' %>"">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </a>
        <a href="/listings?category=Amazing Pools" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Amazing Pools' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </a>
        <a href="/listings?category=Camping" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Camping' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </a>
        <a href="/listings?category=Farms" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Farms' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </a>
        <a href="/listings?category=Arctic" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Arctic' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </a>
        <a href="/listings?category=Domes" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Domes' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-igloo"></i></div>
            <p>Domes</p>
        </a>
        <a href="/listings?category=Boats" class="filter <%= typeof activeCategory !== 'undefined' && activeCategory === 'Boats' ? 'active-filter' : '' %>"">
            <div><i class="fa-solid fa-ship"></i></div>
            <p>Boats</p>
        </a>
        
        <div class="tax-toggle ms-auto">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Display total after Taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <%for(let listing of allListings){%>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem; object-fit: cover;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b><br>
                            &#8377;<%=listing.price.toLocaleString("en-IN")%> /night
                            <i class="tax-info text-muted"> &nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
        <%}%>
        
        <% if(allListings.length === 0) { %>
            <div class="col-12 mt-4 text-center">
                <h5>No listings found in this category!</h5>
                <a href="/listings" class="btn btn-outline-dark mt-2">View All Listings</a>
            </div>
        <% } %>
    </div>

    <script>
        let taxSwitch = document.getElementById("flexSwitchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (let info of taxInfo) {
                // FIXED: Added proper if/else logic so it toggles correctly
                if(info.style.display !== "inline"){
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
            }
        });
    </script>